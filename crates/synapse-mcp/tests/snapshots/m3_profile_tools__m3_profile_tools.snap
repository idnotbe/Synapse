      "additionalProperties": false,
      "properties": {
        "profile_id": {
          "type": "string"
        }
      },
      "required": [
        "profile_id"
      ],
      "title": "ProfileActivateParams",
      "type": "object"
    },
    "name": "profile_activate",
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "active_profile_id": {
          "type": "string"
        },
        "changed": {
          "type": "boolean"
        },
        "previous_active_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile_id": {
          "type": "string"
        }
      },
      "required": [
        "profile_id",
        "active_profile_id",
        "changed"
      ],
      "title": "ProfileActivateResponse",
      "type": "object"
    }
  },
  {
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "include_inactive": {
          "default": true,
          "type": "boolean"
        }
      },
      "title": "ProfileListParams",
      "type": "object"
    },
    "name": "profile_list",
    "outputSchema": {
      "$defs": {
        "Backend": {
          "enum": [
            "software",
            "vigem",
            "hardware",
            "auto"
          ],
          "type": "string"
        },
        "PerceptionMode": {
          "enum": [
            "a11y_only",
            "pixel_only",
            "hybrid",
            "auto"
          ],
          "type": "string"
        },
        "ProfileBackendsStatus": {
          "additionalProperties": false,
          "properties": {
            "default": {
              "$ref": "#/$defs/Backend"
            },
            "keyboard_default": {
              "$ref": "#/$defs/Backend"
            },
            "mouse_default": {
              "$ref": "#/$defs/Backend"
            },
            "pad_default": {
              "$ref": "#/$defs/Backend"
            }
          },
          "required": [
            "default",
            "keyboard_default",
            "mouse_default",
            "pad_default"
          ],
          "type": "object"
        },
        "ProfileEventExtensionStatus": {
          "additionalProperties": false,
          "properties": {
            "emits_kind": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "emits_kind"
          ],
          "type": "object"
        },
        "ProfileMatchStatus": {
          "additionalProperties": false,
          "properties": {
            "exe": {
              "type": [
                "string",
                "null"
              ]
            },
            "title_regex": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "type": "object"
        },
        "ProfileStatus": {
          "additionalProperties": false,
          "properties": {
            "active": {
              "type": "boolean"
            },
            "backends": {
              "$ref": "#/$defs/ProfileBackendsStatus"
            },
            "detection_classes": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "event_extensions": {
              "items": {
                "$ref": "#/$defs/ProfileEventExtensionStatus"
              },
              "type": "array"
            },
            "hud_fields": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "id": {
              "type": "string"
            },
            "keymap_actions": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "label": {
              "type": "string"
            },
            "matches": {
              "items": {
                "$ref": "#/$defs/ProfileMatchStatus"
              },
              "type": "array"
            },
            "metadata": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "mode": {
              "$ref": "#/$defs/PerceptionMode"
            },
            "schema_version": {
              "format": "uint32",
              "minimum": 0,
              "type": "integer"
            },
            "use_scope": {
              "$ref": "#/$defs/ProfileUseScope"
            }
          },
          "required": [
            "id",
            "label",
            "use_scope",
            "mode",
            "detection_classes",
            "hud_fields",
            "keymap_actions",
            "backends",
            "event_extensions",
            "matches",
            "metadata",
            "active",
            "schema_version"
          ],
          "type": "object"
        },
        "ProfileUseScope": {
          "enum": [
            "productivity",
            "single_player",
            "operator_owned_test",
            "sanctioned_research",
            "unknown"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "active_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "profiles": {
          "items": {
            "$ref": "#/$defs/ProfileStatus"
          },
          "type": "array"
        }
      },
      "required": [
        "profiles"
      ],
      "title": "ProfileListResponse",
      "type": "object"
    }
  }
]
